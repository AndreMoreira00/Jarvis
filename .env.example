# Template de variaveis de ambiente do Jarvis.
# Copie para .env e preencha. O .env real NUNCA deve ser versionado.
#   cp .env.example .env

# Chave de API do Google Gemini (OBRIGATORIA).
# Gere em: https://aistudio.google.com/apikey
API_GEMINI=

# --- Credenciais OAuth do Google Photos ---
# Hoje os caminhos sao fixos no codigo (manager.py procura em ./env/):
#   ./env/client_secret.json  (baixado do Google Cloud Console)
#   ./env/token.json          (gerado no 1o login OAuth)
# Esses arquivos ficam em env/ (ignorado pelo git). A parametrizacao via
# variavel de ambiente entra na Onda 5 (config tipada).
